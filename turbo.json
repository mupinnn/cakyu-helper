{
  "$schema": "https://turborepo.dev/schema.json",
  "globalPassThroughEnv": [
    "PUPPETEER_SKIP_DOWNLOAD",
    "PUPPETEER_EXECUTABLE_PATH"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "cakyu-helper-api"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
